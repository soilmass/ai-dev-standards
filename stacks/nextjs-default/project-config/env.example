# .env.example — copied from the preset's project-config/ by new-project.sh.
# Copy to .env.local (gitignored) and fill REAL values; never commit real secrets
# (gitleaks blocks them). The authoritative shape + validation lives in env.schema.ts
# (04-build/secrets-config.md) — this file is the human-copyable checklist of vars.
NODE_ENV=development
# Database (Drizzle) — full connection string, TLS in production
DATABASE_URL=postgres://user:pass@localhost:5432/app
# Better Auth — secret >= 32 chars: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32+-char-random-secret
BETTER_AUTH_URL=http://localhost:3000
# Optional
# SMTP_URL=smtp://user:pass@host:587
# Client-exposed (NEXT_PUBLIC_ only, no secrets)
NEXT_PUBLIC_APP_URL=http://localhost:3000
