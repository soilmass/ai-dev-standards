// prisma/schema.prisma — copied from the preset's project-config/ by new-project.sh.
// Governing doc: 03-design/data-modeling.md. Prisma is this preset's ORM (the
// warm-Node/container deviation — mature migration tooling; ORM decision rule in
// 00-governance/pinned-decisions.md). Conventions encoded below:
//   - snake_case columns/tables via @map/@@map (data-modeling rule 1); Prisma
//     model names stay PascalCase, fields camelCase, mapped to snake_case in DB.
//   - surrogate PK, system-generated, time-sortable (UUIDv7) — rule 4.
//   - created_at/updated_at timestamptz, rule 7.
//   - soft-delete is a per-table EXPLICIT decision (rule 8): items hard-delete in
//     v1; add `deletedAt DateTime? @map("deleted_at")` only where recovery matters.
// Auth tables (User/Session/Account/Verification) are generated by Better Auth's
// CLI (`pnpm dlx @better-auth/cli generate` → emits Prisma models); reconcile their
// column names to snake_case via @map. Migrations: `prisma migrate dev` (local) /
// `prisma migrate deploy` (prod); generated SQL lives in prisma/migrations/** —
// the CI migration guard watches that path. NEVER `prisma db push` in production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Item {
  id        String    @id @default(uuid(7)) @db.Uuid
  userId    String    @map("user_id") // FK to Better Auth's user.id once auth is generated
  url       String
  title     String
  readAt    DateTime? @map("read_at") @db.Timestamptz(6) // null = unread
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("items")
}
