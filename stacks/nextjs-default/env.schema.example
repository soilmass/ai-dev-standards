// env.schema.ts — boot-validated environment schema (copy of this example).
// new-project.sh copies this file to <project>/env.schema.ts.
//
// Rules (see 04-build/secrets-config.md):
// - EVERY env var the app reads is declared here. Reading process.env anywhere
//   else is a lint/review violation; import `serverEnv` / `clientEnv` instead.
// - Validated at boot: import `serverEnv` from the app's server entry (e.g.
//   instrumentation.ts or next.config) so a missing/malformed var fails startup,
//   never request time. Validation failures THROW (never process.exit — this
//   module may be traversed by a bundler; an exit call would kill the build
//   in confusing ways, a thrown Error fails it loudly and points here).
// - SERVER/CLIENT SPLIT IS LOAD-BEARING:
//   * `serverEnv` must only be imported from server code (server components,
//     route handlers, server actions). Importing it in a client component is a
//     review violation — the values are undefined in the browser by design.
//   * `clientEnv` reads each NEXT_PUBLIC_ var as a LITERAL property access —
//     required, because Next.js inlines only literal `process.env.NEXT_PUBLIC_X`
//     expressions into the client bundle. Iterating process.env on the client
//     finds nothing; never refactor these reads into a loop.
// - Real values live in .env.local (gitignored) and the host's env settings —
//   never in this file, never in git. gitleaks enforces this in the pre-commit
//   hook and in CI.

import { z } from 'zod';

// ----- server-only vars (never NEXT_PUBLIC_, never imported client-side) -----
const serverSchema = z.object({
  NODE_ENV: z.enum(['development', 'test', 'production']).default('development'),

  // Database (Drizzle) — full connection string, TLS required in production
  DATABASE_URL: z.string().url(),

  // Better Auth
  BETTER_AUTH_SECRET: z.string().min(32, 'generate with: openssl rand -base64 32'),
  BETTER_AUTH_URL: z.string().url(),

  // Optional integrations — model optional vars explicitly, never with `!`
  SMTP_URL: z.string().url().optional(),
});

// ----- client-exposed vars (NEXT_PUBLIC_ prefix, no secrets) -----
const clientSchema = z.object({
  NEXT_PUBLIC_APP_URL: z.string().url(),
});

function formatIssues(error: z.ZodError): string {
  return error.issues.map((i) => `  - ${i.path.join('.')}: ${i.message}`).join('\n');
}

function parseServer() {
  const parsed = serverSchema.safeParse(process.env);
  if (!parsed.success) {
    throw new Error(`Invalid server environment variables:\n${formatIssues(parsed.error)}`);
  }
  return parsed.data;
}

function parseClient() {
  // Literal property reads — Next.js inlines these at build time (see header).
  const parsed = clientSchema.safeParse({
    NEXT_PUBLIC_APP_URL: process.env.NEXT_PUBLIC_APP_URL,
  });
  if (!parsed.success) {
    throw new Error(`Invalid client environment variables:\n${formatIssues(parsed.error)}`);
  }
  return parsed.data;
}

// Both exports are the parse FUNCTIONS, not their results: validation runs only
// when a caller invokes them, so importing this module has no side effects and
// never throws at import time. Server code calls `serverEnv()`; client code calls
// `clientEnv()` (its NEXT_PUBLIC_ reads are inlined by Next.js — see header).

/** Server-side env. Import ONLY from server code. Call to validate + read. */
export const serverEnv = parseServer;
/** Client-safe env (NEXT_PUBLIC_ only). Safe to import anywhere. Call to read. */
export const clientEnv = parseClient;

// CI runs this file directly (ENV_VALIDATE_ONLY=true) to prove both schemas are
// well-formed and parse against a complete set of values; see
// stacks/nextjs-default/ci/pr.yml. The CI job sets only ENV_VALIDATE_ONLY (no
// real secrets), so this block seeds placeholder-but-valid values for any var
// not already present in the environment, then runs BOTH parsers. This exercises
// the schema shape (types, .url(), .min()) without ever touching real config.
if (process.env.ENV_VALIDATE_ONLY === 'true') {
  const placeholders: Record<string, string> = {
    NODE_ENV: 'production',
    DATABASE_URL: 'postgres://user:pass@localhost:5432/app',
    BETTER_AUTH_SECRET: 'x'.repeat(32),
    BETTER_AUTH_URL: 'https://example.com',
    NEXT_PUBLIC_APP_URL: 'https://example.com',
  };
  for (const [key, value] of Object.entries(placeholders)) {
    if (process.env[key] === undefined) process.env[key] = value;
  }
  serverEnv();
  clientEnv();
  console.log('✅ env schema valid (server + client)');
}
